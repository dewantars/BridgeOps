apiVersion: v1
kind: Secret
metadata:
  name: laravel-secret
  labels:
    app: bridgeops
type: Opaque
data:
  # Salin file ini menjadi laravel-secret.yaml dan isi value di bawah ini dengan base64 encoded string:
  # Linux/macOS: echo -n 'your-value' | base64
  # Windows PowerShell: [System.Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes('your-value'))
  
  # Masukkan base64 dari APP_KEY (contoh: base64:xxx)
  APP_KEY: ""
  
  # Masukkan base64 dari DB_PASSWORD
  DB_PASSWORD: ""
  
  # Masukkan base64 dari GEMINI_API_KEY
  GEMINI_API_KEY: ""
  
  # Masukkan base64 dari GITHUB_WEBHOOK_SECRET
  GITHUB_WEBHOOK_SECRET: ""
